---
import feedData from '../data/medium.generated.json';
import configData from '../data/medium.config.json';

type FeedItem = {
  title: string;
  url: string;
  date?: string;
  excerpt?: string;
};

type FeedData = {
  source?: {
    title?: string;
    url?: string;
  };
  lastUpdated?: string;
  items?: FeedItem[];
};

type ConfigData = {
  heading?: string;
  sourceLabel?: string;
  sourceUrl?: string;
};

const feed = feedData as FeedData;
const config = configData as ConfigData;

const items = feed.items ?? [];
const heading = config.heading || 'Writing';
const sourceTitle = feed.source?.title || config.sourceLabel || 'Medium';
const sourceUrl = feed.source?.url || config.sourceUrl;

const formatDate = (value?: string) => {
  if (!value) return null;
  const date = new Date(value);
  if (Number.isNaN(date.getTime())) return null;
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric'
  });
};
---

<section aria-labelledby="medium-heading" class="space-y-5">
  <div class="flex flex-wrap items-baseline justify-between gap-2">
    <h2 id="medium-heading" class="text-xl font-semibold">{heading}</h2>
    {sourceUrl && (
      <a href={sourceUrl} class="text-sm font-semibold text-accent underline underline-offset-4">
        View all on Medium
      </a>
    )}
  </div>

  {items.length > 0 ? (
    <div class="flex flex-col gap-7">
      {items.map((item) => (
        <article class="space-y-3">
          <div class="flex flex-col gap-2">
            <h3 class="text-lg font-semibold">
              <a href={item.url} class="text-accent underline underline-offset-4">
                {item.title}
              </a>
            </h3>
            {formatDate(item.date) && (
              <p class="text-sm leading-snug text-muted">{formatDate(item.date)}</p>
            )}
          </div>
          {item.excerpt && <p>{item.excerpt}</p>}
        </article>
      ))}
    </div>
  ) : (
    <p class="text-muted">No posts available yet.</p>
  )}
</section>
