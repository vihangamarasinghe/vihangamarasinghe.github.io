---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import type { LinkItem } from '../data/links';

type Props = {
  name: string;
  role: string;
  links: LinkItem[];
  imageSrc: ImageMetadata;
  imageAlt: string;
};

const { name, role, links, imageSrc, imageAlt } = Astro.props;
---

<header class="flex flex-col items-center gap-6 md:flex-row md:items-center md:justify-between">
  <div class="flex flex-col items-center gap-4 text-center md:flex-1 md:items-start md:text-left">
    <div class="flex flex-col gap-2">
      <h1 class="text-3xl font-semibold tracking-tight">{name}</h1>
      <p class="text-lg text-muted">{role}</p>
    </div>
    <nav aria-label="Primary">
      <ul class="flex flex-wrap justify-center gap-3 md:justify-start">
        {links.map((link) => (
          <li>
            <a href={link.href} class="text-accent underline underline-offset-4">
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
  <div class="shrink-0 self-center md:self-auto">
    <Image
      src={imageSrc}
      alt={imageAlt}
      width={160}
      height={160}
      class="h-32 w-32 rounded-full object-cover"
      loading="eager"
      decoding="async"
    />
  </div>
</header>
