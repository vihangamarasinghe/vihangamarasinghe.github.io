---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Intro from '../components/Intro.astro';
import Projects from '../components/Projects.astro';
import Experience from '../components/Experience.astro';
import Footer from '../components/Footer.astro';

import { profile } from '../data/profile';
import { links } from '../data/links';
import { projects } from '../data/projects';
import { experience } from '../data/experience';

const headerLinks = links.filter((link) => link.kinds.includes('primary'));
const footerLinks = links.filter((link) =>
  link.kinds.some((kind) => kind === 'contact' || kind === 'resume')
);
---

<BaseLayout title={`${profile.name} — ${profile.role}`} description={profile.intro}>
  <main class="mx-auto flex w-full max-w-2xl flex-col gap-14 px-6 py-12 text-base leading-relaxed">
    <Header name={profile.name} role={profile.role} links={headerLinks} />
    <Intro text={profile.intro} />
    <Projects items={projects} />
    <Experience items={experience} />
    <Footer links={footerLinks} />
  </main>
</BaseLayout>
